{
  "name": "@task-manager/api",
  "version": "0.0.0",
  "private": true,
  "packageManager": "pnpm@10.30.3",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --env-file=.env src/index.ts",
    "build": "tsc --noEmit && tsup",
    "migrate": "tsx src/infrastructure/database/migrate.ts",
    "start": "node dist/index.js",
    "clean": "rm -rf dist",
    "test": "vitest run",
    "lint": "biome check .",
    "lint:fix": "biome check --write ."
  },
  "dependencies": {
    "@fastify/cors": "^11.0.0",
    "@scalar/fastify-api-reference": "^1.48.4",
    "@task-manager/shared": "workspace:*",
    "fastify": "^5.2.0",
    "pg": "^8.13.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^25.4.0",
    "@types/pg": "^8.11.0",
    "tsup": "^8.5.1",
    "tsx": "^4.19.0",
    "typescript": "^5.8.3",
    "vitest": "^3.2.4"
  }
}
